<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.wa.toolkit.ui.preferences.CardPreferenceCategory
        android:title="@string/category_app_management">

        <androidx.preference.SwitchPreferenceCompat
            android:key="update_check"
            android:defaultValue="true"
            android:summary="@string/update_check_sum"
            android:title="@string/update_check"
            app:icon="@drawable/ic_round_update_24" />

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="disable_expiration"
            android:summary="@string/disable_whatsapp_expiration_sum"
            android:title="@string/disable_whatsapp_expiration"
            app:icon="@drawable/airplane_disabled" />

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="bypass_version_check"
            android:summary="@string/disable_version_check_sum"
            android:title="@string/disable_version_check"
            app:icon="@drawable/ic_round_bug_report_24" />

    </com.wa.toolkit.ui.preferences.CardPreferenceCategory>

    <com.wa.toolkit.ui.preferences.CardPreferenceCategory
        android:title="@string/category_interface_system">

        <androidx.preference.ListPreference
            android:entries="@array/thememode_entries"
            android:entryValues="@array/thememode_values"
            android:key="thememode"
            android:summary="%s"
            android:title="@string/theme_mode"
            app:icon="@drawable/ic_dashboard_black_24dp" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="lite_mode"
            android:summary="@string/lite_mode_sum"
            android:title="@string/lite_mode"
            app:icon="@drawable/ic_round_check_circle_24" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="enable_spy"
            android:summary="@string/enable_spy_sum"
            android:title="@string/enable_spy"
            app:icon="@drawable/eye_enabled" />

        <com.wa.toolkit.preference.FloatSeekBarPreference
            android:defaultValue="0"
            android:key="change_dpi"
            app:maxValue="600"
            app:minValue="0"
            android:title="@string/change_default_dpi"
            app:icon="@drawable/ic_round_settings_24" />

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="haptic_feedback"
            android:summary="@string/haptic_feedback_sum"
            android:title="@string/haptic_feedback"
            app:icon="@drawable/ic_check_circle" />

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="enablelogs"
            android:title="@string/verbose_logs"
            app:icon="@drawable/edit" />

    </com.wa.toolkit.ui.preferences.CardPreferenceCategory>

    <com.wa.toolkit.ui.preferences.CardPreferenceCategory
        android:title="@string/category_advanced_tweaks">

        <androidx.preference.SwitchPreferenceCompat
            android:summary="@string/bootloader_spoofer_sum"
            android:title="@string/bootloader_spoofer"
            android:key="bootloader_spoofer"
            app:icon="@drawable/ic_round_warning_24" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="tasker"
            android:summary="@string/enable_tasker_automation_sum"
            android:title="@string/enable_tasker_automation"
            app:icon="@drawable/ic_round_settings_24" />

    </com.wa.toolkit.ui.preferences.CardPreferenceCategory>

</PreferenceScreen>