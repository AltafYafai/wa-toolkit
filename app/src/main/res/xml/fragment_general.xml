<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.wa.toolkit.ui.preferences.CardPreferenceCategory
        android:title="Interface &amp; Layout">

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="floatingmenu"
            android:summary="Modern centered action menu"
            android:title="Floating Home Menu"
            app:icon="@drawable/ic_dashboard_black_24dp" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="novaconfig"
            android:summary="Redesigned settings navigation"
            android:title="Experimental Settings UI"
            app:icon="@drawable/ic_round_settings_24" />

        <androidx.preference.ListPreference
            android:defaultValue="2"
            android:entries="@array/chatfilter_buttons"
            android:entryValues="@array/chatfilter_values"
            android:key="chatfilter"
            android:summary="%s"
            android:title="Home Filter Style"
            app:icon="@drawable/ic_home_black_24dp" />

    </com.wa.toolkit.ui.preferences.CardPreferenceCategory>

    <com.wa.toolkit.ui.preferences.CardPreferenceCategory
        android:title="Visual Enhancements">

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="menuwicon"
            android:summary="Show icons next to menu items"
            android:title="Menu Icons"
            app:icon="@drawable/about" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="animation_emojis"
            android:summary="Smooth animated emoji interactions"
            android:title="Animated Emojis"
            app:icon="@drawable/ic_round_check_circle_24" />

        <androidx.preference.ListPreference
            android:defaultValue="default"
            android:entries="@array/animations_names"
            android:entryValues="@array/animations_values"
            android:key="animation_list"
            android:summary="%s"
            android:title="List Animations"
            app:icon="@drawable/ic_dashboard_black_24dp" />

    </com.wa.toolkit.ui.preferences.CardPreferenceCategory>

    <com.wa.toolkit.ui.preferences.CardPreferenceCategory
        android:title="Intelligence">

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="voice_transcription"
            android:summary="@string/voice_transcription_sum"
            android:title="@string/voice_transcription"
            app:icon="@drawable/ic_recording" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="ai_rewrite"
            android:summary="@string/ai_rewrite_sum"
            android:title="@string/ai_rewrite"
            app:icon="@drawable/ic_privacy" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="group_tldr"
            android:summary="@string/group_tldr_sum"
            android:title="@string/group_tldr"
            app:icon="@drawable/ic_home_black_24dp" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="metaai"
            android:summary="Completely hide Meta AI integration"
            android:title="Disable Meta AI"
            app:icon="@drawable/ic_round_bug_report_24" />

    </com.wa.toolkit.ui.preferences.CardPreferenceCategory>

    <com.wa.toolkit.ui.preferences.CardPreferenceCategory
        android:title="Advanced Workflow">

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="disable_pinned_limit"
            android:summary="@string/disable_pinned_limit_sum"
            android:title="@string/disable_pinned_limit"
            app:icon="@drawable/ic_dashboard_black_24dp" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="zen_mode"
            android:summary="@string/zen_mode_sum"
            android:title="@string/zen_mode"
            app:icon="@drawable/eye_disabled" />

    </com.wa.toolkit.ui.preferences.CardPreferenceCategory>

</PreferenceScreen>