        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="always_online"
            android:summary="@string/always_online_sum"
            android:title="@string/always_online"
            app:icon="@drawable/online" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="showonline"
            android:summary="@string/show_toast_on_contact_online_sum"
