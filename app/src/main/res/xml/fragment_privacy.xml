<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.wa.toolkit.ui.preferences.CardPreferenceCategory
        android:title="Anti-Revoke &amp; Security">

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="antirevoke"
            android:summary="@string/antirevoke_sum"
            android:title="@string/antirevoke"
            app:icon="@drawable/deleted" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="antirevokestatus"
            android:summary="@string/antirevokestatus_sum"
            android:title="@string/antirevokestatus"
            app:icon="@drawable/ic_round_warning_24" />

        <androidx.preference.Preference
            android:key="open_deleted_messages"
            android:summary="Browse and manage all captured deleted content"
            android:title="View Deleted Messages"
            app:icon="@drawable/ic_delete" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="antidisappearing"
            android:summary="@string/antidisappearing_sum"
            android:title="@string/antidisappearing"
            app:icon="@drawable/ic_privacy" />

        <rikka.material.preference.MaterialSwitchPreference
            android:defaultValue="false"
            android:key="revokeallmessages"
            android:summary="@string/delete_for_everyone_all_messages_sum"
            android:title="@string/delete_for_everyone_all_messages"
