<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/title_image">

        <androidx.preference.SwitchPreferenceCompat
            android:key="imagequality"
            android:summary="@string/imagequality_sum"
            android:title="@string/imagequality" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="download_profile"
            android:summary="Add a download button when viewing profile pictures"
            android:title="Download Profile Picture" />

    </PreferenceCategory>

    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/download_title">

        <com.wa.toolkit.preference.FileSelectPreference
            android:defaultValue="/sdcard/Download"
            app:directory="true"
            android:key="download_local"
            android:title="@string/local_download" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="downloadviewonce"
            android:summary="@string/downloadviewonce_sum"
            android:title="@string/downloadviewonce" />

    </PreferenceCategory>

    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/title_video">

        <com.wa.toolkit.preference.FloatSeekBarPreference
            android:defaultValue="60"
            android:key="video_limit_size"
            app:maxValue="90"
            app:minValue="30"
            android:title="@string/increase_video_size_limit"
            app:valueSpacing="10" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="videoquality"
            android:summary="@string/videoquality_sum"
            android:title="@string/videoquality" />

        <androidx.preference.SwitchPreferenceCompat
            android:dependency="videoquality"
            android:key="video_real_resolution"
            android:summary="@string/send_video_in_real_resolution_sum"
            android:title="@string/send_video_in_real_resolution" />

        <androidx.preference.SwitchPreferenceCompat
            android:dependency="videoquality"
            android:key="video_maxfps"
            android:summary="@string/send_video_in_60fps_sum"
            android:title="@string/send_video_in_60fps" />
    </PreferenceCategory>

    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/title_audio">

        <androidx.preference.SwitchPreferenceCompat
            android:key="disable_sensor_proximity"
            android:summary="@string/disable_the_proximity_sensor_sum"
            android:title="@string/disable_the_proximity_sensor" />


        <androidx.preference.SwitchPreferenceCompat
            android:key="proximity_audios"
            android:summary="@string/disable_audio_sensor_sum"
            android:title="@string/disable_audio_sensor" />

        <ListPreference
            android:defaultValue="0"
            android:entries="@array/audio_type_buttons"
            android:entryValues="@array/audio_type_values"
            android:key="audio_type"
            android:summary="@string/send_audio_as_voice_audio_note_sum"
            android:title="@string/send_audio_as_voice_audio_note" />

        <com.wa.toolkit.preference.FloatSeekBarPreference
            android:defaultValue="2"
            android:key="voicenote_speed"
            app:maxValue="5"
            app:minValue="0.1"
            android:title="@string/voice_note_speed" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="audio_transcription"
            android:summary="@string/audio_transcription_sum"
            android:title="@string/audio_transcription" />

        <ListPreference
            android:dependency="audio_transcription"
            android:defaultValue="assemblyai"
            android:entries="@array/transcription_provider_entries"
            android:entryValues="@array/transcription_provider_values"
            android:key="transcription_provider"
            android:summary="@string/transcription_provider_sum"
            android:title="@string/transcription_provider" />

        <EditTextPreference
            android:dependency="audio_transcription"
            android:key="assemblyai_key"
            android:summary="@string/assemblyai_key_sum"
            android:title="@string/assemblyai_key" />

        <EditTextPreference
            android:dependency="audio_transcription"
            android:key="groq_api_key"
            android:summary="@string/groq_api_key_sum"
            android:title="@string/groq_api_key" />

    </PreferenceCategory>

    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/other">

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="media_preview"
            android:summary="@string/enable_media_preview_sum"
            android:title="@string/enable_media_preview" />

    </PreferenceCategory>

</PreferenceScreen>
