<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/category_message_protection">

        <ListPreference
            android:entries="@array/antirevoke_entries"
            android:entryValues="@array/antirevoke_values"
            app:iconSpaceReserved="false"
            android:key="antirevoke"
            android:summary="@string/antirevoke_sum"
            android:title="@string/antirevoke" />

        <ListPreference
            android:entries="@array/antirevoke_entries"
            android:entryValues="@array/antirevoke_values"
            app:iconSpaceReserved="false"
            android:key="antirevokestatus"
            android:summary="@string/antirevokestatus_sum"
            android:title="@string/antirevokestatus" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="antidisappearing"
            android:summary="@string/antidisappearing_sum"
            android:title="@string/antidisappearing" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="antieditmessages"
            android:summary="@string/show_edited_message_history_sum"
            android:title="@string/show_edited_message_history" />

        <Preference
            android:key="open_deleted_messages"
            android:summary="@string/deleted_messages_sum"
            android:title="@string/deleted_messages_title" />

    </PreferenceCategory>

    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/category_safe_interaction">

        <androidx.preference.SwitchPreferenceCompat
            android:key="verify_blocked_contact"
            android:summary="@string/show_contact_blocked_sum"
            android:title="@string/show_contact_blocked" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="alertsticker"
            android:summary="@string/enable_confirmation_to_send_sticker_sum"
            android:title="@string/enable_confirmation_to_send_sticker" />

    </PreferenceCategory>

    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/category_chat_enhancements">

        <androidx.preference.SwitchPreferenceCompat
            android:key="pinnedlimit"
            android:summary="@string/disable_pinned_limit_sum"
            android:title="@string/disable_pinned_limit" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="removeforwardlimit"
            android:summary="@string/removeforwardlimit_sum"
            android:title="@string/removeforwardlimit" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="hidetag"
            android:summary="@string/hidetag_sum"
            android:title="@string/hidetag" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="broadcast_tag"
            android:summary="@string/show_chat_broadcast_icon_sum"
            android:title="@string/show_chat_broadcast_icon" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="revokeallmessages"
            android:summary="@string/delete_for_everyone_all_messages_sum"
            android:title="@string/delete_for_everyone_all_messages" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="removeseemore"
            android:summary="@string/remove_see_more_button_"
            android:title="@string/remove_see_more_button" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="remove_limit_edit_message"
            android:summary="@string/remove_limit_edit_message_sum"
            android:title="@string/remove_limit_edit_message" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="show_admin_group_icon"
            android:summary="@string/show_admin_group_icon_sum"
            android:title="@string/show_admin_group_icon" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="animation_emojis"
            android:summary="@string/animation_emojis_sum"
            android:title="@string/animation_emojis" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="new_context_menu_ui"
            android:summary="@string/new_context_menu_ui_sum"
            android:title="@string/new_context_menu_ui" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="disable_audio_sensor"
            android:summary="@string/disable_audio_sensor_sum"
            android:title="@string/disable_audio_sensor" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="disable_defemojis"
            android:summary="@string/disable_default_emojis_sum"
            android:title="@string/disable_default_emojis" />

    </PreferenceCategory>

    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/category_interactions_tools">

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="doubletap2like"
            android:summary="@string/double_click_to_like_sum"
            android:title="@string/double_click_to_react" />

        <com.wa.toolkit.preference.LimitedEditTextPreference
            android:defaultValue="👍"
            android:dependency="doubletap2like"
            android:key="doubletap2like_emoji"
            app:maxLength="2"
            android:summary="@string/custom_reaction_sum"
            android:title="@string/custom_reaction" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="google_translate"
            android:summary="@string/google_translate_sum"
            android:title="@string/google_translate" />

        <Preference
            android:key="read_all_mark_as_read"
            android:summary="Mark all chats as read with one click"
            android:title="@string/read_all_mark_as_read" />

        <androidx.preference.SwitchPreferenceCompat
            android:key="stamp_copied_message"
            android:summary="@string/stamp_copied_messages_sum"
            android:title="@string/stamp_copied_messages" />

    </PreferenceCategory>

</PreferenceScreen>