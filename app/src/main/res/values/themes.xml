<resources>

    <!-- Global App Theme -->
    <style name="Base.AppTheme" parent="Theme.Material3.DynamicColors.Dark.Rikka">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        
        <!-- Expressive M3 Attributes -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Modern Colors -->
        <item name="colorPrimary">@color/md_theme_dark_primary</item>
        <item name="colorOnPrimary">@color/md_theme_dark_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_dark_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_dark_onPrimaryContainer</item>
        <item name="colorSurface">@color/md_theme_dark_surface</item>
        <item name="colorOnSurface">@color/md_theme_dark_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_dark_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_dark_outline</item>

        <!-- Preference Styling -->
        <item name="preferenceTheme">@style/ModernPreferenceTheme</item>
        <item name="toolbarStyle">@style/ModernToolbarStyle</item>
    </style>

    <style name="Theme" parent="Base.AppTheme" />

    <!-- Modern Preference Theme (The "Clean & Attractive" part) -->
    <style name="ModernPreferenceTheme" parent="@style/PreferenceThemeOverlay.Material3">
        <item name="switchPreferenceCompatStyle">@style/ModernSwitchStyle</item>
    </style>

    <!-- Beautiful Togles (M3 Expressive Style) -->
    <style name="ModernSwitchStyle" parent="@style/Preference.Material3.SwitchPreferenceCompat">
        <item name="android:layout">@layout/rikkax_material_switch_preference</item>
    </style>

    <style name="ModernToolbarStyle" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">?textAppearanceTitleLarge</item>
        <item name="android:background">?colorSurface</item>
    </style>

    <!-- Card Styles -->
    <style name="ExpressiveCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

</resources>
