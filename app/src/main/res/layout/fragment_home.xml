<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <rikka.widget.borderview.BorderNestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        app:borderBottomVisibility="never"
        app:borderTopVisibility="whenTop">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp">

            <!-- Main Module Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/status"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="28dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/status_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:srcCompat="@drawable/ic_round_check_circle_24"
                        app:tint="?attr/colorPrimary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/status_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/module_enabled"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/status_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:alpha="0.7"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            tools:text="Version 1.0.0" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- WhatsApp Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/status2"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/status_icon2"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:srcCompat="@drawable/ic_round_check_circle_24"
                        app:tint="?attr/colorPrimary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/status_title2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/whatsapp_in_background"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/status_summary1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.7"
                            android:textAppearance="?attr/textAppearanceBodySmall" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/reboot_btn"
                        style="?attr/materialIconButtonFilledStyle"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@drawable/ic_reload"
                        app:iconSize="20dp"
                        app:iconTint="?attr/colorOnPrimaryContainer"
                        app:backgroundTint="?attr/colorPrimaryContainer" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- WhatsApp Business Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/status3"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/status_icon3"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:srcCompat="@drawable/ic_round_check_circle_24"
                        app:tint="?attr/colorPrimary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/status_title3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/business_in_background"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/status_summary3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.7"
                            android:textAppearance="?attr/textAppearanceBodySmall" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/reboot_btn2"
                        style="?attr/materialIconButtonFilledStyle"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@drawable/ic_reload"
                        app:iconSize="20dp"
                        app:iconTint="?attr/colorOnPrimaryContainer"
                        app:backgroundTint="?attr/colorPrimaryContainer" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Device Info Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="System Information"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/info_card"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/android_version" android:textAppearance="?attr/textAppearanceLabelSmall" android:alpha="0.6" />
                        <TextView android:id="@+id/sdk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceBodyMedium" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/device_name" android:textAppearance="?attr/textAppearanceLabelSmall" android:alpha="0.6" />
                        <TextView android:id="@+id/device_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceBodyMedium" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/device_model" android:textAppearance="?attr/textAppearanceLabelSmall" android:alpha="0.6" />
                        <TextView android:id="@+id/model_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceBodyMedium" android:textStyle="bold" />
                    </LinearLayout>

                </GridLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actions Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="Management"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/importBtn"
                            style="?attr/materialButtonElevationLessStyle"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_margin="4dp"
                            android:layout_weight="1"
                            android:text="@string/import_settings"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/refresh" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/exportBtn"
                            style="?attr/materialButtonElevationLessStyle"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_margin="4dp"
                            android:layout_weight="1"
                            android:text="@string/export_settings"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/download" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/resetBtn"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_margin="4dp"
                        android:text="@string/reset_settings"
                        android:textColor="?attr/colorError"
                        app:cornerRadius="20dp"
                        app:strokeColor="?attr/colorError" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Supported Versions Info -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/list_wpp_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/list_wpp"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:alpha="0.6" />

                    <TextView
                        android:id="@+id/list_wpp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/list_business"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:alpha="0.6" />

                    <TextView
                        android:id="@+id/list_business"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </rikka.widget.borderview.BorderNestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
